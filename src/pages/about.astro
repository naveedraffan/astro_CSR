---
import Layout from '@/layouts/Layout.astro';

const stack = [
  { name: 'Astro 5',         role: 'Framework',       color: '#f97316' },
  { name: 'TypeScript',      role: 'Language',         color: '#3b82f6' },
  { name: 'Yarn 4',          role: 'Package manager',  color: '#2563eb' },
  { name: 'Vite',            role: 'Bundler',          color: '#a855f7' },
  { name: 'Vanilla JS',      role: 'Client logic',     color: '#eab308' },
  { name: 'localStorage',    role: 'Client storage',   color: '#22c55e' },
];
---

<Layout title="About" description="About this Astro CSR sample project">
  <h1>About this project</h1>
  <p class="sub">A quick-start Astro CSR template with Yarn and a custom build output directory.</p>

  <section class="section">
    <h2>Build configuration</h2>
    <div class="code-block">
      <pre><code>{`// astro.config.mjs
export default defineConfig({
  output: 'static',   // CSR / SSG mode
  outDir: './build',  // custom output directory
  build: {
    assets: '_assets',
    inlineStylesheets: 'auto',
  },
});`}</code></pre>
    </div>
    <p class="note">
      Run <code>yarn build</code> → all static files land in <code>./build/</code>.
      Serve that folder from any CDN or static host (Netlify, Vercel, GitHub Pages, S3 + CloudFront…).
    </p>
  </section>

  <section class="section">
    <h2>Tech stack</h2>
    <div class="stack-grid">
      {stack.map(s => (
        <div class="stack-card" style={`border-color: ${s.color}33`}>
          <div class="dot" style={`background: ${s.color}`}></div>
          <div>
            <div class="stack-name">{s.name}</div>
            <div class="stack-role">{s.role}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Scripts reference</h2>
    <table>
      <thead><tr><th>Command</th><th>What it does</th></tr></thead>
      <tbody>
        <tr><td><code>yarn install</code></td><td>Install all dependencies</td></tr>
        <tr><td><code>yarn dev</code></td><td>Start dev server at <code>http://localhost:4321</code></td></tr>
        <tr><td><code>yarn build</code></td><td>Build to <code>./build/</code> for production</td></tr>
        <tr><td><code>yarn preview</code></td><td>Preview the <code>./build/</code> output locally</td></tr>
      </tbody>
    </table>
  </section>
</Layout>

<style>
  h1 { font-size: 2rem; font-weight: 800; margin-bottom: .4rem; }
  .sub { color: var(--muted); margin-bottom: 2rem; }

  .section { margin-bottom: 2.5rem; }
  h2 { font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; color: var(--brand); }

  .code-block {
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
    overflow: auto; margin-bottom: .75rem;
  }
  pre { padding: 1.25rem 1.5rem; }
  code { font-size: .82rem; color: #a5f3fc; font-family: monospace; }

  .note { font-size: .85rem; color: var(--muted); line-height: 1.7; }
  .note code { background: var(--surface); padding: .1em .35em; border-radius: 4px; color: var(--brand); font-size: .85em; }

  .stack-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: .75rem; }
  .stack-card {
    display: flex; align-items: center; gap: .75rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: .75rem 1rem;
  }
  .dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .stack-name { font-size: .875rem; font-weight: 600; }
  .stack-role { font-size: .75rem; color: var(--muted); margin-top: .1rem; }

  table { width: 100%; border-collapse: collapse; font-size: .875rem; }
  th, td { text-align: left; padding: .6rem .75rem; border-bottom: 1px solid var(--border); }
  th { color: var(--muted); font-weight: 600; }
  td code { background: var(--surface); padding: .1em .35em; border-radius: 4px; font-size: .82em; color: var(--brand); }
</style>
